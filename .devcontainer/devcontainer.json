{
    "name": "CppUTestTemplate",
    "image": "davidcozens/cpputest:sha-9b8e96e",
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "remoteUser": "developer",
    "updateRemoteUserUID": false,
    "context": "..",
    "runArgs": ["--cap-add=SYS_PTRACE", "--security-opt", "seccomp=unconfined"],
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "xaver.clang-format",
                "[c]": { "editor.defaultFormatter": "xaver.clang-format" },
                "[cpp]": { "editor.defaultFormatter": "xaver.clang-format" },
                "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json"
            },
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "jeff-hykin.better-cpp-syntax",
                "anthropic.claude-code",
                "xaver.clang-format"
            ]
        }
    },
    "postStartCommand": "git config --global core.sshCommand /usr/bin/ssh",
    "mounts": [
        "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind",
        "source=${localEnv:HOME}/.claude,target=/home/developer/.claude,type=bind",
        "source=${localEnv:HOME}/.config/gh,target=/home/developer/.config/gh,type=bind"
    ],
    "remoteEnv": {
        "SSH_AUTH_SOCK": "/ssh-agent"
    }
}
